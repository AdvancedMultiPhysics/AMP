dim=3

CartesianGeometry{
   domain_boxes = [(0,0,0), (31,15,0)]
   x_lo         = 0.0, 0.0, 0.0
   x_up         = 0.1, 0.1, 0.1
   periodic_dimension = 0,1,1
}

GriddingAlgorithm{
   combine_efficiency = 0.95
   efficiency_tolerance = 0.95
}

PatchHierarchy{
   max_levels = 3
   largest_patch_size {
      level_0 = 32,32,1
   }
   smallest_patch_size {
      level_0 = 4,4,1
   }
   ratio_to_coarser {
      level_1  = 2, 2, 1
      level_2  = 2, 2, 1
   }
}


StandardTagAndInitialize{
   tagging_method = "REFINE_BOXES"
   level_0{
       boxes = [(0,0,0),(7,15,0)], [(24,0,0),(31,15,0)]
   }
   level_1 {
       boxes = [(0,0,0),(7,31,0)], [(56,0,0),(63,31,0)]
   }
}


ChopAndPackLoadBalancer {
  bin_pack_method       = "SPATIAL"
	ignore_level_box_union_is_single_box = TRUE
}

